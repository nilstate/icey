FROM node:22-bookworm-slim

LABEL maintainer="0state OSS <oss@0state.com>"

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
  doxygen \
  graphviz \
  make \
  ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

CMD ["make", "docs"]
