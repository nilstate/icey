// Map CMPixelFormatType to FFmpeg pixel format name
static const char* pixelFormatName(FourCharCode fmt)
{
    switch (fmt) {
        case kCVPixelFormatType_420YpCbCr8BiPlanarVideoRange:
        case kCVPixelFormatType_420YpCbCr8BiPlanarFullRange:
            return "nv12";
        case kCVPixelFormatType_422YpCbCr8:
            return "uyvy422";
        case kCVPixelFormatType_422YpCbCr8_yuvs:
            return "yuyv422";
        case kCVPixelFormatType_32BGRA:
            return "bgra";
        case kCVPixelFormatType_32ARGB:
            return "argb";
        case kCVPixelFormatType_420YpCbCr8Planar:
            return "yuv420p";
        default:
            return "unknown";
    }
}


bool GetAVFoundationVideoDevices(Device::Type type, std::vector<Device>* devices)
{
#if !__has_feature(objc_arc)
  NSAutoreleasePool* pool = [[NSAutoreleasePool alloc] init];
#else
  @autoreleasepool
#endif
  {
    // Use AVCaptureDeviceDiscoverySession (replaces deprecated [AVCaptureDevice devices])
    NSArray<AVCaptureDeviceType>* deviceTypes;
    NSString* mediaType = nil;

    // AVCaptureDeviceTypeExternal (macOS 14+) replaces
    // AVCaptureDeviceTypeExternalUnknown (macOS 10.15-13.x)
    AVCaptureDeviceType externalType = nil;
#if defined(__MAC_OS_X_VERSION_MAX_ALLOWED) && __MAC_OS_X_VERSION_MAX_ALLOWED >= 140000
    if (@available(macOS 14.0, *)) {
        externalType = AVCaptureDeviceTypeExternal;
    } else
#endif
    {
#pragma clang diagnostic push
#pragma clang diagnostic ignored "-Wdeprecated-declarations"
        externalType = AVCaptureDeviceTypeExternalUnknown;
#pragma clang diagnostic pop
    }

    if (type == Device::VideoInput) {
        deviceTypes = @[
            AVCaptureDeviceTypeBuiltInWideAngleCamera,
            externalType
        ];
        mediaType = AVMediaTypeVideo;
    } else if (type == Device::AudioInput) {
        deviceTypes = @[
            AVCaptureDeviceTypeBuiltInMicrophone,
            externalType
        ];
        mediaType = AVMediaTypeAudio;
    } else {
        return false;
    }

    AVCaptureDeviceDiscoverySession* discoverySession =
        [AVCaptureDeviceDiscoverySession
            discoverySessionWithDeviceTypes:deviceTypes
            mediaType:mediaType
            position:AVCaptureDevicePositionUnspecified];

    NSArray<AVCaptureDevice*>* capture_devices = discoverySession.devices;
    LDebug([capture_devices count], " capture device(s) found:");

    for (AVCaptureDevice* capture_device in capture_devices) {
        static NSString* const kFormat = @"localizedName: \"%@\", "
            @"modelID: \"%@\", uniqueID \"%@\", isConnected: %d, "
            @"isInUseByAnotherApplication: %d";
        NSString* info = [NSString
            stringWithFormat:kFormat,
                             [capture_device localizedName],
                             [capture_device modelID],
                             [capture_device uniqueID],
                             [capture_device isConnected],
                             [capture_device isInUseByAnotherApplication]];
        LDebug('\t', [info UTF8String]);

        std::string uniqueID([[capture_device uniqueID] UTF8String]);
        std::string name([[capture_device localizedName] UTF8String]);
        Device device(type, uniqueID, name);
        device.isConnected = [capture_device isConnected] ? true : false;
        device.isInUse = [capture_device isInUseByAnotherApplication] ? true : false;

        // Query capabilities from device formats
        if (type == Device::VideoInput) {
            for (AVCaptureDeviceFormat* format in [capture_device formats]) {
                CMFormatDescriptionRef desc = [format formatDescription];
                CMVideoDimensions dims = CMVideoFormatDescriptionGetDimensions(desc);
                FourCharCode pixFmt = CMFormatDescriptionGetMediaSubType(desc);

                // Get frame rate ranges
                for (AVFrameRateRange* range in [format videoSupportedFrameRateRanges]) {
                    Device::VideoCapability cap;
                    cap.width = dims.width;
                    cap.height = dims.height;
                    cap.minFps = [range minFrameRate];
                    cap.maxFps = [range maxFrameRate];
                    cap.pixelFormat = pixelFormatName(pixFmt);

                    // Avoid duplicates
                    bool dup = false;
                    for (auto& existing : device.videoCapabilities) {
                        if (existing.width == cap.width && existing.height == cap.height
                            && existing.maxFps == cap.maxFps && existing.pixelFormat == cap.pixelFormat) {
                            dup = true;
                            break;
                        }
                    }
                    if (!dup)
                        device.videoCapabilities.push_back(std::move(cap));
                }
            }
        }

        devices->push_back(std::move(device));
    }
  }
#if !__has_feature(objc_arc)
  [pool drain];
#endif
  return true;
}


