set ffmpeg_ver      8

depends_build-append \
                    path:bin/pkg-config:pkgconfig

depends_lib-append  \
                    path:libexec/ffmpeg${ffmpeg_ver}/lib/libavcodec.dylib:ffmpeg${ffmpeg_ver} \
                    port:libuv \
                    port:llhttp \
                    port:minizip \
                    port:zlib

