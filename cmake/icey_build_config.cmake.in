@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

function(_icey_add_compat_target compat_target actual_target)
  if(TARGET "${actual_target}" AND NOT TARGET "${compat_target}")
    add_library("${compat_target}" INTERFACE IMPORTED)
    set_property(TARGET "${compat_target}" PROPERTY INTERFACE_LINK_LIBRARIES "${actual_target}")
  endif()
endfunction()

function(_icey_add_libuv_compat_target compat_target)
  if(@BUILD_SHARED_LIBS@)
    _icey_add_compat_target("${compat_target}" libuv::uv)
    _icey_add_compat_target("${compat_target}" libuv::libuv)
    _icey_add_compat_target("${compat_target}" PkgConfig::LIBUV)
    _icey_add_compat_target("${compat_target}" libuv::uv_a)
  else()
    _icey_add_compat_target("${compat_target}" libuv::uv_a)
    _icey_add_compat_target("${compat_target}" libuv::uv)
    _icey_add_compat_target("${compat_target}" libuv::libuv)
    _icey_add_compat_target("${compat_target}" PkgConfig::LIBUV)
  endif()
endfunction()

set(_icey_supported_components "@icey_BUILD_MODULES@")
set(_icey_have_libdatachannel "@HAVE_LIBDATACHANNEL@")

find_dependency(Threads)
find_package(PkgConfig QUIET)

if(@HAVE_OPENSSL@)
  find_dependency(OpenSSL)
endif()

if(@HAVE_OPENCV@)
  find_dependency(OpenCV)
endif()

if(_icey_have_libdatachannel AND DEFINED icey_FIND_COMPONENTS AND "webrtc" IN_LIST icey_FIND_COMPONENTS)
  if(NOT TARGET LibDataChannel::LibDataChannelStatic AND NOT TARGET LibDataChannel::LibDataChannel)
    find_dependency(LibDataChannel CONFIG)
  endif()
endif()

if(@USE_SYSTEM_DEPS@)
  find_package(libuv CONFIG QUIET)
  if(NOT TARGET libuv::uv_a AND NOT TARGET libuv::uv AND NOT TARGET libuv::libuv AND PkgConfig_FOUND)
    pkg_check_modules(LIBUV QUIET IMPORTED_TARGET GLOBAL libuv)
  endif()
  find_package(llhttp CONFIG QUIET)
  if(NOT TARGET llhttp_static
     AND NOT TARGET llhttp::llhttp_static
     AND NOT TARGET llhttp::llhttp_shared
     AND NOT TARGET llhttp::llhttp
     AND NOT TARGET llhttp
     AND PkgConfig_FOUND)
    pkg_check_modules(LLHTTP QUIET IMPORTED_TARGET GLOBAL llhttp)
    if(NOT TARGET PkgConfig::LLHTTP)
      pkg_check_modules(LLHTTP QUIET IMPORTED_TARGET GLOBAL libllhttp)
    endif()
  endif()
  find_dependency(ZLIB)
  _icey_add_libuv_compat_target(icey_libuv)
  _icey_add_compat_target(llhttp_static llhttp::llhttp_static)
  _icey_add_compat_target(llhttp_static llhttp::llhttp_shared)
  _icey_add_compat_target(llhttp_static llhttp::llhttp)
  _icey_add_compat_target(llhttp_static llhttp)
  _icey_add_compat_target(llhttp_static PkgConfig::LLHTTP)
  if(NOT TARGET icey_libuv)
    message(FATAL_ERROR "icey requires libuv via a CMake package config or pkg-config")
  endif()
  if(NOT TARGET llhttp_static)
    message(FATAL_ERROR "icey requires llhttp via a CMake package config or pkg-config")
  endif()
  if("archo" IN_LIST _icey_supported_components OR "pacm" IN_LIST _icey_supported_components)
    find_dependency(unofficial-minizip CONFIG QUIET)
    find_dependency(minizip CONFIG QUIET)
    if(NOT TARGET unofficial-minizip::minizip AND NOT TARGET minizip::minizip AND PkgConfig_FOUND)
      pkg_check_modules(MINIZIP QUIET IMPORTED_TARGET GLOBAL minizip)
    endif()
    _icey_add_compat_target(minizip unofficial-minizip::minizip)
    _icey_add_compat_target(minizip minizip::minizip)
    _icey_add_compat_target(minizip PkgConfig::MINIZIP)
    if(NOT TARGET minizip)
      message(FATAL_ERROR "icey archo/pacm components require minizip via a CMake package config or pkg-config")
    endif()
  endif()
else()
  include("${CMAKE_CURRENT_LIST_DIR}/iceyVendoredTargets.cmake")
  _icey_add_compat_target(icey_libuv uv_a)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/iceyTargets.cmake")

foreach(_icey_component ${_icey_supported_components})
  set(icey_${_icey_component}_FOUND TRUE)
endforeach()

check_required_components(icey)
